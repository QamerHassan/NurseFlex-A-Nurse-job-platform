datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  NURSE
  BUSINESS
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role       @default(NURSE)
  status        UserStatus @default(PENDING)
  isOnboarded   Boolean    @default(false)
  createdAt     DateTime   @default(now())
  
  accounts      Account[]
  sessions      Session[]
  
  profile       Profile?
  applications  Application[]
  savedJobs     SavedJob[]
  notifications Notification[]
  subscriptions BusinessSubscription[]
  issueReports  IssueReport[]
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  phone        String?
  country      String?
  postcode     String?
  bio          String?
  experience   Int      @default(0)
  skills       String[] 
  location     String?
  resumeUrl    String?  
  
  // --- Onboarding Pay Details ---
  minPay       Int?
  payPeriod    String?  // "hour", "year"
  currency     String?  // "Rs", "$", "£"
  jobTypes     String[] // ["Full-time", "Part-time", ...]
  jobTitles    String[] // ["Registered Nurse", "ICU Nurse", ...]
  
  userId       String   @unique @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  hospital     String
  location     String
  salary       String
  type         String        
  description  String
  createdAt    DateTime      @default(now())

  applications Application[]
  savedJobs    SavedJob[]
  issueReports IssueReport[]
}

model Application {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  status      String   @default("Pending") 
  resumeUrl   String?  
  appliedAt   DateTime @default(now())

  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId       String   @db.ObjectId
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

// --- 🔥 UPDATED BLOG MODEL ---
model Blog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String   // Yahan long-term explanation aur detail description ayegi
  imageUrl    String?  // Blog ki feature image ka link
  status      String   @default("Published") // Draft, Published
  category    String   @default("Nursing Tips")
  author      String   @default("Admin")
  views       Int      @default(0)
  createdAt   DateTime @default(now()) // Post ki original date handle karega
  updatedAt   DateTime @updatedAt      // Edit hone par update hoga
}

model ServiceRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  email       String
  phone       String
  serviceType String
  message     String
  status      String   @default("Pending") 
  createdAt   DateTime @default(now())
}

model SavedJob {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String   @db.ObjectId
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
}

model Conversation {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  participantIds String[]  @db.ObjectId
  messages       Message[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Message {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String       @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String       @db.ObjectId
  content        String
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // "JOB_ALERT", "APPLICATION_UPDATE", "MESSAGE"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// --- SUBSCRIPTION MODELS ---
model SubscriptionTier {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // "Starter", "Pro", etc.
  price       Int
  jobsLimit   Int
  features    String[] // Array of included features
  isPopular   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions BusinessSubscription[]
}

model BusinessSubscription {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  status          String   @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  startDate       DateTime @default(now())
  endDate         DateTime? 
  jobsPostedCount Int      @default(0) 
  
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tierId          String   @db.ObjectId
  tier            SubscriptionTier @relation(fields: [tierId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model IssueReport {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  category  String
  message   String
  status    String   @default("PENDING") // PENDING, RESOLVED, IGNORED
  
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  jobId     String?  @db.ObjectId // Optional, may not be related to a specific job
  job       Job?     @relation(fields: [jobId], references: [id])
  
  createdAt DateTime @default(now())
}